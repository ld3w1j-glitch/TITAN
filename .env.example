SECRET_KEY=troque-por-uma-chave-segura
DB_PATH=/data/titan.db
UPLOAD_PATH=/data/uploads

# Envio recomendado no Railway gratuito: API HTTPS da Brevo.
MAIL_MODE=brevo_api
BREVO_API_KEY=COLE_AQUI_SUA_CHAVE_COMPLETA_DA_BREVO
BREVO_SENDER_EMAIL=remetente-verificado@exemplo.com
BREVO_SENDER_NAME=TITAN

# Para desenvolvimento sem envio real, use MAIL_MODE=console.

# SMTP continua disponível como alternativa opcional:
# MAIL_MODE=smtp
# SMTP_HOST=smtp.seu-provedor.com
# SMTP_PORT=587
# SMTP_USERNAME=seu-email@exemplo.com
# SMTP_PASSWORD=senha-ou-chave-do-aplicativo
# SMTP_FROM_EMAIL=seu-email@exemplo.com
# SMTP_FROM_NAME=Projeto TITAN
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
